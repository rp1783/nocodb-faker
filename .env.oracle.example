# NoCoDB Configuration
NC_AUTH_JWT_SECRET=your_super_secret_jwt_key_here_change_this

# NoCoDB API Token (get this from NoCoDB after first login)
NOCODB_API_TOKEN=your_nocodb_api_token_here

# Table IDs (get these from NoCoDB URLs after creating tables)
TABLE_ID=your_contacts_table_id
EMPLOYEES_TABLE_ID=your_employees_table_id
VEHICLES_TABLE_ID=your_vehicles_table_id
CASES_TABLE_ID=your_cases_table_id

# Data Generation Settings
NUM_CONTACTS=100
NUM_EMPLOYEES=20
NUM_VEHICLES=50
NUM_CASES=30

# API Wrapper Configuration
API_PORT=3000
NOCODB_WRAPPER_API_KEY=your_secure_api_key_for_wrapper

# Oracle Instance Configuration
# Your Oracle instance public IP
ORACLE_PUBLIC_IP=your.oracle.instance.ip

# Your domain (if you have one)
DOMAIN=nocodb.yourdomain.com
API_DOMAIN=api.nocodb.yourdomain.com
